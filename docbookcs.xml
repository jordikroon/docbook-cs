<?xml version="1.0" encoding="UTF-8"?>
<docbookcs xmlns="https://docbookcs.org/config">

	<!-- Sniff registration by FQCN -->
	<sniffs>
		<sniff class="DocbookCS\Sniff\SimparaSniff" />
	</sniffs>

	<!-- Paths to scan (relative to config file or absolute) -->
	<paths>
		<path>reference/</path>
		<path>language/</path>
		<path>appendices/intro.xml</path>
	</paths>

	<!-- Exclude patterns (fnmatch style) -->
	<exclude>
		<pattern>*/skeleton.xml</pattern>
		<pattern>reference/*/versions.xml</pattern>
	</exclude>

	<!-- Entity directories/files (may live outside root) -->
	<entities>
		<directory>../doc-base/entities/</directory>
		<file>../doc-base/entities/global.ent</file>
	</entities>

</docbookcs>
